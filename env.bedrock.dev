MAX_GRAPH_NODES=10000
ENABLE_LLM_CACHE_FOR_EXTRACT=true
SUMMARY_LANGUAGE=English
MAX_UPLOAD_SIZE=104857600
ENTITY_TYPES=["Organ", "Equipment", "Cell", "Chemical", "Reagent", "Disease", "Event", "Concept", "Method", "Content", "Data", "Artifact", "NaturalObject"]
MAX_ASYNC=1
MAX_PARALLEL_INSERT=1
EMBEDDING_FUNC_MAX_ASYNC=1
LLM_BINDING=aws_bedrock
LLM_MODEL=us.amazon.nova-2-lite-v1:0
AWS_REGION=us-east-1
BEDROCK_LLM_TEMPERATURE=1.0
EMBEDDING_BINDING=aws_bedrock
EMBEDDING_MODEL=amazon.nova-2-multimodal-embeddings-v1:0
